# OBRIGATÓRIO — copie este arquivo para .env e ajuste os valores ANTES de subir os containers
# Sem este arquivo, o docker compose up falhará explicitamente.
#
#   cp .env.example .env
#   (edite .env com uma senha forte)

POSTGRES_DB=appcontas
POSTGRES_USER=contas
POSTGRES_PASSWORD=troque_por_uma_senha_forte

# Chave secreta para assinar os tokens JWT — gere com:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque_por_32_chars_aleatorios
JWT_EXPIRE_HOURS=24

# --- PERSISTÊNCIA DE DADOS (USO EM PRODUÇÃO/PORTAINER) ---
# Se os containers rodarem localmente via `docker compose up`, o padrão é criar "./data" e "./backups".
# No Portainer via Stacks (Git Setup), defina estes caminhos na UI para persistir em pastas definitivas do servidor.
DB_DATA_PATH=/caminho/absoluto/no/seu/servidor/data
BACKUP_DATA_PATH=/caminho/absoluto/no/seu/servidor/backups

# --- REDE ---
# Porta host do frontend (padrão: 3333)
APP_PORT=3333

# --- CORS ---
# Origens permitidas para chamadas à API. Separe múltiplos valores por vírgula.
# Use o IP ou domínio pelo qual você acessa o frontend no browser.
# Exemplo: ALLOWED_ORIGINS=http://192.168.1.100:3333,https://meudominio.com
# Se não definida, a API aceita qualquer origem (menos seguro).
ALLOWED_ORIGINS=http://SEU-IP-OU-DOMINIO:3333

